# Doc Reader — LLM API 配置示例
# 复制本文件为 src-tauri/.env 并填入你自己的密钥（.env 已在 .gitignore 中）

# ========== LLM API 配置 ==========
# 选择你的 LLM 提供商：openai / anthropic / custom（OpenAI 兼容端点）
LLM_PROVIDER=custom

# ────── custom：任意 OpenAI 兼容端点 ──────
# 火山方舟 / DeepSeek / 智谱 / Moonshot / SiliconFlow 等都走这条
CUSTOM_API_KEY=your-api-key-here
CUSTOM_API_BASE=https://api.example.com/v1
CUSTOM_MODEL=your-model-id

# ────── OpenAI 官方 ──────
OPENAI_API_KEY=sk-...
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# ────── Anthropic Claude ──────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ========== 可选：多模型池 ==========
# 应用内 SettingsPage 也支持图形化配置多模型轮询负载均衡，
# 优先级：app_data/llm_models.json > 本 .env
